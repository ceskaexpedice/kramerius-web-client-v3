    "@angular/core": "^21.2.8",
    "@angular/forms": "^21.2.8",
    "@angular/google-maps": "^21.2.6",
    "@angular/material": "^21.2.6",
    "@angular/material-moment-adapter": "^21.2.6",
    "@angular/platform-browser": "^21.2.8",
    "@angular/platform-browser-dynamic": "^21.2.8",
    "@angular/router": "^21.2.8",
    "@ngrx/effects": "^21.1.0",
    "@ngrx/entity": "^21.1.0",
    "@ngrx/router-store": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@schematics/angular": "^21.2.7",
    "epubjs": "^0.3.93",
    "file-saver": "^2.0.5",
    "font-awesome": "^4.7.0",
    "highlight.js": "^11.11.1",
    "moment": "^2.30.1",
    "ngx-extended-pdf-viewer": "^26.0.4",
    "ngx-translate-multi-http-loader": "^20.0.0",
    "openseadragon": "^6.0.2",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.8",
    "@axe-core/cli": "^4.11.1",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~6.0.0",
    "@types/openseadragon": "^5.0.2",
    "axe-core": "^4.11.3",
    "jasmine-axe": "^1.1.0",
    "jasmine-core": "~6.2.0",
