{
  "name": "cdk-client",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/bootstrap_file_environment-local-ts.js && node scripts/collect-build-info.js",
    "start": "ng serve",
    "prebuild": "node scripts/generate_file_env-json.js && node scripts/collect-build-info.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:a11y": "ng test --include='**/*.a11y.spec.ts'",
    "axe": "axe http://localhost:4200 --save axe-results.json --tags wcag2aa"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.11",
    "@angular/cdk": "^20.2.13",
    "@angular/common": "^20.3.11",
    "@angular/compiler": "^20.3.11",
    "@angular/core": "^20.3.11",
    "@angular/forms": "^20.3.11",
    "@angular/material": "^20.2.13",
    "@angular/material-moment-adapter": "^20.2.13",
    "@angular/platform-browser": "^20.3.11",
    "@angular/platform-browser-dynamic": "^20.3.11",
    "@angular/router": "^20.3.11",
    "@ngrx/effects": "^20.1.0",
    "@ngrx/entity": "^20.1.0",
    "@ngrx/router-store": "^20.1.0",
    "@ngrx/store": "^20.1.0",
    "@ngrx/store-devtools": "^20.1.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "@schematics/angular": "^20.3.10",
    "file-saver": "^2.0.5",
    "font-awesome": "^4.7.0",
    "moment": "^2.30.1",
    "ngx-extended-pdf-viewer": "^25.6.0-alpha.3",
    "ngx-translate-multi-http-loader": "^20.0.0",
    "openseadragon": "^5.0.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.10",
    "@angular/cli": "^20.3.10",
    "@angular/compiler-cli": "^20.3.11",
    "@axe-core/cli": "^4.11.0",
    "@types/file-saver": "^2.0.7",
    "@types/jasmine": "~5.1.12",
    "@types/openseadragon": "^5.0.1",
    "axe-core": "^4.11.0",
    "jasmine-axe": "^1.1.0",
    "jasmine-core": "~5.12.1",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  }
}
